#!/bin/bash
prefix="${PASSWORD_STORE_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/password-store}"
password_files=( "$prefix"/**/*.gpg )
password_files=( "${password_files[@]#"$prefix"/}" )
password_files=( "${password_files[@]%.gpg}" )
password=$(printf "%s\n" "${password_files[@]}" | fuzzel --dmenu "$@")

[[ -n "$password" ]] && {
    pkill -STOP clipman
    pass show "$password" | head -n 1 | tr -d '\n' | wl-copy
	notify-send "Success!" "You have 45 seconds only."
    (sleep 45 && wl-copy --clear && pkill -CONT clipman) &
    disown
}
